{
  "name": "neuralminds",
  "version": "0.1.0",
  "description": "Autonomous market infrastructure on Base",
  "scripts": {
    "lint:fix": "prettier */*.js \"*/**/*{.js,.ts}\" -w",
    "lint": "prettier */*.js \"*/**/*{.js,.ts}\" --check",
    "test": "anchor test",
    "launch:config": "node scripts/validate-launch-config.mjs --mode=production --write-report",
    "launch:config:soft": "node scripts/validate-launch-config.mjs --mode=production --allow-missing-secrets --write-report",
    "launch:readiness": "bash scripts/launch-readiness.sh --mode=production --allow-missing-secrets",
    "launch:readiness:strict": "bash scripts/launch-readiness.sh --strict --mode=production --allow-missing-secrets",
    "launch:summary": "node scripts/generate-launch-summary.mjs",
    "launch:e2e": "npm run launch:readiness && npm run production:gates",
    "synthetic:check": "node scripts/synthetic-monitor.mjs",
    "base:smoke:sepolia": "node scripts/base-sepolia-smoke.mjs",
    "base:web:e2e:sepolia": "node scripts/base-sepolia-web-smoke.mjs",
    "load:baseline:report": "node scripts/load-baseline-report.mjs",
    "production:gates": "node scripts/production-loop-report.mjs",
    "production:gates:strict": "node scripts/production-loop-report.mjs --strict",
    "base:wallets:status": "bash scripts/base-wallet-status.sh --network both",
    "base:fund:sepolia": "bash scripts/base-distribute-funds.sh --network sepolia",
    "base:fund:mainnet": "bash scripts/base-distribute-funds.sh --network mainnet",
    "evm:build": "forge build --root evm",
    "evm:test": "forge test --root evm",
    "evm:fmt": "forge fmt --root evm",
    "evm:deploy:base-sepolia": "forge script script/DeployCore.s.sol:DeployCoreScript --root evm --rpc-url $BASE_SEPOLIA_RPC_URL --account $FOUNDRY_ACCOUNT --broadcast --verify",
    "evm:deploy:base": "forge script script/DeployCore.s.sol:DeployCoreScript --root evm --rpc-url $BASE_RPC_URL --account $FOUNDRY_ACCOUNT --broadcast --verify",
    "evm:deploy:programs:base-sepolia": "forge script script/DeployPrograms.s.sol:DeployProgramsScript --root evm --rpc-url $BASE_SEPOLIA_RPC_URL --account $FOUNDRY_ACCOUNT --broadcast --verify",
    "evm:deploy:programs:base": "forge script script/DeployPrograms.s.sol:DeployProgramsScript --root evm --rpc-url $BASE_RPC_URL --account $FOUNDRY_ACCOUNT --broadcast --verify",
    "evm:deploy:timelock:base": "forge script script/DeployTimelock.s.sol:DeployTimelockScript --root evm --rpc-url $BASE_RPC_URL --account $FOUNDRY_ACCOUNT --broadcast --verify",
    "evm:deploy:timelock:base-sepolia": "forge script script/DeployTimelock.s.sol:DeployTimelockScript --root evm --rpc-url $BASE_SEPOLIA_RPC_URL --account $FOUNDRY_ACCOUNT --broadcast --verify",
    "evm:handoff:timelock:base": "forge script script/HandoffToTimelock.s.sol:HandoffToTimelockScript --root evm --rpc-url $BASE_RPC_URL --account $FOUNDRY_ACCOUNT --broadcast",
    "evm:handoff:timelock:base-sepolia": "forge script script/HandoffToTimelock.s.sol:HandoffToTimelockScript --root evm --rpc-url $BASE_SEPOLIA_RPC_URL --account $FOUNDRY_ACCOUNT --broadcast",
    "evm:deploy:programs:sepolia:run": "bash scripts/base-deploy-programs.sh --network sepolia",
    "evm:deploy:programs:mainnet:run": "bash scripts/base-deploy-programs.sh --network mainnet"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.31.1",
    "@solana/spl-token": "^0.4.0",
    "@solana/web3.js": "^1.95.0",
    "next-pwa": "^5.6.0",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@types/bn.js": "^5.1.5",
    "@types/chai": "^4.3.16",
    "@types/mocha": "^10.0.7",
    "chai": "^4.4.1",
    "mocha": "^10.6.0",
    "prettier": "^3.3.2",
    "ts-mocha": "^10.0.0",
    "typescript": "^5.5.3"
  }
}
