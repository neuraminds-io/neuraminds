# Polyguard Environment Configuration
# Copy this file to .env and fill in your values

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_DB=polyguard
POSTGRES_PORT=5432
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/${POSTGRES_DB}

# Redis
REDIS_URL=redis://localhost:6379

# JWT (generate with: openssl rand -base64 32)
JWT_SECRET=your-jwt-secret-here

# Solana
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_ENABLED=false
KEEPER_KEYPAIR_PATH=./keeper.json

# Program IDs (deployed addresses)
MARKET_PROGRAM_ID=
ORDERBOOK_PROGRAM_ID=
PRIVACY_PROGRAM_ID=

# Base (EVM pivot)
CHAIN_MODE=base
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_WS_URL=wss://sepolia.base.org
BASE_CHAIN_ID=8453
BASE_SEPOLIA_CHAIN_ID=84532
BASESCAN_API_KEY=
SIWE_DOMAIN=localhost:3000
FOUNDRY_ACCOUNT=base-deployer
BASE_ADMIN=
BASE_TREASURY=
BASE_DEPLOYER=
BASE_PAUSER=
BASE_RESOLVER=
BASE_MATCHER=
BASE_OPERATOR=
BASE_MARKET_CREATOR=
BOOTSTRAP_ADMIN=
NEURA_CAP_WEI=1000000000000000000000000000
NEURA_INITIAL_SUPPLY_WEI=100000000000000000000000000
COLLATERAL_TOKEN_BASE_MAINNET=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
COLLATERAL_TOKEN_BASE_SEPOLIA=0x036CbD53842c5426634e7929541eC2318f3dCF7e
COLLATERAL_TOKEN_ADDRESS=
NEURA_TOKEN_ADDRESS=
MARKET_CORE_ADDRESS=
ORDER_BOOK_ADDRESS=
COLLATERAL_VAULT_ADDRESS=
EVM_ENABLED=false
EVM_READS_ENABLED=false
EVM_WRITES_ENABLED=false
LEGACY_READS_ENABLED=true
LEGACY_WRITES_ENABLED=true

# Server
HOST=127.0.0.1
PORT=8080
RUST_LOG=info
