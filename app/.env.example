# Neuraminds Backend Configuration (Base only)

# Server
HOST=0.0.0.0
PORT=8080

# Database
DATABASE_URL=postgres://postgres:password@localhost:5432/polyguard

# Redis
REDIS_URL=redis://localhost:6379

# Base
CHAIN_MODE=base
BASE_RPC_URL=https://sepolia.base.org
BASE_WS_URL=wss://sepolia.base.org
BASE_CHAIN_ID=84532
SIWE_DOMAIN=localhost:3000
EVM_ENABLED=true
EVM_READS_ENABLED=true
EVM_WRITES_ENABLED=true
NEURA_TOKEN_ADDRESS=
MARKET_CORE_ADDRESS=
ORDER_BOOK_ADDRESS=
AGENT_RUNTIME_ADDRESS=
PROGRAM_VAULT_ADDRESS=
USDC_MINT=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# Auth
JWT_SECRET=your-secret-key-change-in-production

# Integrations
BLINDFOLD_WEBHOOK_SECRET=dev-blindfold-secret

# Region routing policy for external provider rails
REGION_ROUTING_ENABLED=false
REGION_ROUTING_MODE=enforce
REGION_UNKNOWN_POLICY=safe_fallback
REGION_COUNTRY_HEADER_PRIORITY=cf-ipcountry,x-vercel-ip-country,x-country-code
LIMITLESS_RESTRICTED_COUNTRIES=US

# Limitless market liquidity gating
LIMITLESS_MARKET_MIN_24H_VOLUME_USDC=25000
LIMITLESS_MARKET_MIN_ORDERBOOK_DEPTH_USDC=2500
LIMITLESS_LIQUIDITY_CHECK_CONCURRENCY=8

# External agent execution
EXTERNAL_MARKETS_ENABLED=true
EXTERNAL_TRADING_ENABLED=true
EXTERNAL_AGENTS_ENABLED=true
EXTERNAL_EXECUTION_MODE=paper
ADMIN_WALLETS=
EXTERNAL_CREDENTIALS_MASTER_KEY=
EXTERNAL_CREDENTIALS_KEY_ID=v1

# Paper trading runner
PAPER_HOLD_DURATION_SECONDS=3600
PAPER_FEE_BPS=30
PAPER_RUNNER_SCAN_LIMIT=200
